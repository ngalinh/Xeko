# ===== SERVER (ai.basso.vn) =====

# URL của máy local qua Cloudflare Tunnel
# Ví dụ: https://automation.basso.vn
PLAYWRIGHT_LOCAL_URL=https://association-requesting-directly-installations.trycloudflare.com

# API Key bảo mật giữa server và máy local (đặt cùng giá trị ở cả 2 máy)
LOCAL_API_KEY=basso-xeko-fb

# Port web server (server)
PORT=3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# n8n Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook/fb-post

# ===== MÁY LOCAL =====

# Port local server (máy local)
LOCAL_PORT=3001

# Facebook profiles (máy local)
FB_LINHTHAO_EMAIL=email@gmail.com
FB_LINHTHAO_PASSWORD=password
FB_LINHTHAO_NAME=Linh Thảo US

FB_LINHDUONG_EMAIL=email@gmail.com
FB_LINHDUONG_PASSWORD=password
FB_LINHDUONG_NAME=Linh Duong

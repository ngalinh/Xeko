# ============================================================
#  Xeko – Local Server (.env)
#  Chỉ chứa biến mà máy local thực sự dùng.
# ============================================================

# API Key bảo mật giữa ai.basso.vn và máy local.
# Phải khớp với LOCAL_API_KEY trên server ai.basso.vn.
LOCAL_API_KEY=change-this-secret-key

# Port HTTP cho local server (Express). Mặc định 3001.
LOCAL_PORT=3001

# (Tuỳ chọn) URL của remote bot trên ai.basso.vn.
# Chỉ cần khi chạy bằng start.js + Cloudflare Tunnel để tự đăng ký URL tunnel.
# Nếu cấu hình PLAYWRIGHT_LOCAL_URL bằng IP trực tiếp ở admin panel
# thì có thể để trống / bỏ qua.
REMOTE_BOT_URL=https://ai.basso.vn/b/your-bot-id

# URL của máy local có Chromium đã cài (server/local-server.js đang chạy).
# Bot remote sẽ forward mọi thao tác Playwright (mở trình duyệt, đăng nhập,
# đăng bài, kiểm tra session...) tới URL này thay vì chạy trực tiếp.
# Bắt buộc cấu hình trên bot remote nếu máy chạy bot KHÔNG có Chromium.
# Ví dụ: http://180.93.36.109:3001 (IP public + LOCAL_PORT của máy local).
# Để trống nếu chạy Playwright trực tiếp trên cùng máy với bot.
PLAYWRIGHT_LOCAL_URL=
